{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "Tec-91-create-industry-table",
        "author": "driemtax",
        "changes": [
          {
            "createTable": {
              "tableName": "industry",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": {
                      "primaryKey": true,
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "name",
                    "type": "VARCHAR(255)",
                    "constraints": {
                      "nullable": false,
                      "unique": true
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "grant-permissions-industry",
        "author": "driemtax",
        "changes": [
          {
            "sql": {
              "dbms": "postgresql",
              "sql": "GRANT SELECT, INSERT, UPDATE, DELETE ON TABLE industry TO ${APP_USER};"
            }
          },
          {
            "sql": {
              "dbms": "postgresql", 
              "sql": "GRANT USAGE, SELECT, UPDATE ON SEQUENCE industry_id_seq TO ${APP_USER};"
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "add-industry-reference-to-project",
        "author": "driemtax",
        "changes": [
          {
            "addColumn": {
              "tableName": "project",
              "columns": [
                {
                  "column": {
                    "name": "industry_id",
                    "type": "BIGINT",
                    "constraints": {
                      "nullable": true,
                      "foreignKeyName": "fk_project_industry",
                      "referencedTableName": "industry",
                      "referencedColumnNames": "id"
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
