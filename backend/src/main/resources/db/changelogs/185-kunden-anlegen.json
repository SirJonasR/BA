{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "185-kunden-anlegen-1",
        "author": "epi2000",
        "changes": [
          {
            "createTable": {
              "tableName": "customer",
              "columns": [
                {
                  "column": {
                    "name": "name",
                    "type": "VARCHAR(60)",
                    "constraints": {
                      "primaryKey": true,
                      "nullable": false,
                      "unique": true
                    }
                  }
                }
              ]
            }
          },
          {
            "createTable": {
              "tableName": "technology_customer",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "constraints": {
                      "nullable": false,
                      "primaryKey": true,
                      "primaryKeyName": "technology_customer_pkey"
                    }
                  }
                },
                {
                  "column": {
                    "name": "customer_name",
                    "type": "VARCHAR(60)",
                    "constraints": {
                      "deleteCascade": true,
                      "nullable": false,
                      "primaryKey": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "technology_id",
                    "type": "BIGINT",
                    "constraints": {
                      "deleteCascade": true,
                      "nullable": false,
                      "primaryKey": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "lifecycle_id",
                    "type": "BIGINT"
                  }
                }
              ]
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "technology_customer",
              "baseColumnNames": "technology_id",
              "constraintName": "technology_fk",
              "referencedTableName": "technology",
              "referencedColumnNames": "id",
              "onDelete": "CASCADE"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "technology_customer",
              "baseColumnNames": "customer_name",
              "constraintName": "customer_fk",
              "referencedTableName": "customer",
              "referencedColumnNames": "name",
              "onDelete": "CASCADE"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "technology_customer",
              "baseColumnNames": "lifecycle_id",
              "constraintName": "lifecycle_fk",
              "deferrable": false,
              "initiallyDeferred": false,
              "onDelete": "NO ACTION",
              "onUpdate": "NO ACTION",
              "referencedTableName": "lifecycle",
              "referencedColumnNames": "id",
              "validate": true
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "185-kunden-anlegen-2",
        "author": "epi2000",
        "changes": [
          {
            "sql": {
              "dbms": "postgresql",
              "sql": "grant select, insert, update, delete on table technology_customer to ${APP_USER};"
            }
          },
          {
            "sql": {
              "dbms": "postgresql",
              "sql": "grant select, insert, update, delete on table customer to ${APP_USER};"
            }
          }
        ]
      }
    }
  ]
